# ============================================================
#  SafeGuardian Backend - Environment Variables
#  Điền thông tin thật vào các trường còn trống bên dưới
# ============================================================

# --- Firebase ---
# Đường dẫn tới file service account JSON (để trong src/main/resources)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Project ID lấy từ Firebase Console > Project settings
FIREBASE_PROJECT_ID=

# --- Email (Gmail SMTP) ---
# Tài khoản Gmail dùng để gửi cảnh báo
MAIL_USERNAME=
# App Password (không phải mật khẩu Gmail thường)
# Hướng dẫn tạo App Password: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=
# Địa chỉ hiển thị trong trường "From"
MAIL_FROM=SafeGuardian <your-email@gmail.com>

# --- Server ---
SERVER_PORT=8080
